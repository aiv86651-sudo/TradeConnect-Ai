{
  "name": "outreach-platform-server",
  "version": "1.0.0",
  "type": "commonjs",
  "main": "server.ts",
  "scripts": {
    "start": "ts-node --project tsconfig.json server.ts",
    "dev": "nodemon --watch '**/*.ts' --exec \"ts-node --project tsconfig.json\" server.ts",
    "build": "tsc"
  },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "twilio": "^5.4.3",
    "resend": "^4.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.13.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "nodemon": "^3.1.9"
  }
}
